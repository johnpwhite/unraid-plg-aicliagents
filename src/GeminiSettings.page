<script>
function saveGeminiSettings(form) {
    const formData = new FormData(form);
    const params = new URLSearchParams(formData);

    fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=save', {
        method: 'POST',
        headers: { 
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-CSRF-Token': '<?=$csrf_token?>'
        },
        body: params.toString()
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'ok') {
            if (typeof swal === 'function') {
                swal({
                    title: "Settings Saved",
                    text: "Changes applied. Some settings may require a terminal restart. Restart now?",
                    type: "success",
                    showCancelButton: true,
                    confirmButtonText: "Restart Terminal",
                    cancelButtonText: "Later"
                }, function(confirmed) {
                    if (confirmed) {
                        fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=restart')
                        .then(() => window.location.reload());
                    } else {
                        window.location.reload();
                    }
                });
            } else {
                if (confirm("Settings saved. Restart terminal now?")) {
                    fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=restart')
                    .then(() => window.location.reload());
                } else {
                    window.location.reload();
                }
            }
        }
    })
    .catch(err => {
        console.error("Save failed:", err);
        alert("Failed to save settings. Check browser console for details.");
    });
}
</script>
