<script>
function saveGeminiSettings(form) {
    const formData = new FormData(form);
    // Add all current config values to the form data to ensure we don't lose them
    // as we have split the UI into two cards/forms
    const currentConfig = <?=json_encode($config)?>;
    for (const [key, value] of Object.entries(currentConfig)) {
        if (!formData.has(key)) {
            formData.append(key, value);
        }
    }

    fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=save', {
        method: 'POST',
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'ok') {
            if (typeof swal === 'function') {
                swal({
                    title: "Settings Saved",
                    text: "Terminal profile updated. Some changes require a session restart. Restart now?",
                    type: "success",
                    showCancelButton: true,
                    confirmButtonText: "Restart Terminal",
                    cancelButtonText: "Later"
                }, function(confirmed) {
                    if (confirmed) {
                        fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=restart')
                        .then(() => window.location.reload());
                    } else {
                        window.location.reload();
                    }
                });
            } else {
                if (confirm("Settings saved. Restart terminal now?")) {
                    fetch('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=restart')
                    .then(() => window.location.reload());
                } else {
                    window.location.reload();
                }
            }
        }
    });
}
</script>
