<style>
/* 
   SCORCHED EARTH on scrollbars. 
   We force hidden on EVERY potential parent wrapper.
*/
body, 
#displaybox, 
#sb-body, 
.gemini-cli-ui, 
main, 
#main-content {
    overflow: hidden !important;
}

#displaybox {
    padding: 0 !important;
    margin-bottom: 0 !important;
}

/* Remove bottom margin from the "Gemini CLI" page title bar and title row */
div.title, .title {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
}

/* Force the main content area to take full width and no padding */
#main-content {
    padding: 0 !important;
}

#gemini-cli-root {
    width: 100%;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    overflow: hidden;
}

.gemini-cli-ui {
    height: 100%;
    width: 100%;
}
</style>

<script>
$(function(){
    // Dynamically size the root to fill from its top edge to 6px above the footer
    function resizeRoot() {
        var el = document.getElementById('gemini-cli-root');
        if (!el) return;
        var rect = el.getBoundingClientRect();
        var footerHeight = 30; // Unraid footer bar approx height
        var padding = 6;       // Small gap above footer
        var available = window.innerHeight - rect.top - footerHeight - padding;
        el.style.height = Math.max(200, available) + 'px';
    }
    // Run on load, on resize, and after React mounts
    resizeRoot();
    window.addEventListener('resize', resizeRoot);
    setTimeout(resizeRoot, 500);
    setTimeout(resizeRoot, 1500);
});
</script>
