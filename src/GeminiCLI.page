<style>
/* 
   SCORCHED EARTH on scrollbars. 
   We force hidden on EVERY potential parent wrapper.
*/
html,
body, 
#displaybox, 
#sb-body, 
.gemini-cli-ui, 
main, 
#main-content,
#gemini-cli-root,
.main-section {
    overflow: hidden !important;
