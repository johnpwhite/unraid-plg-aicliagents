<div id="gemini-cli-root"></div>

<link rel="stylesheet" href="/plugins/unraid-geminicli/assets/ui/index.css?v=<?= $version ?>">
<script type="module" src="/plugins/unraid-geminicli/assets/ui/index.js?v=<?= $version ?>"></script>

<style>
/* Kill all outer scrollbars */
body, #displaybox, #sb-body, .gemini-cli-ui {
    overflow: hidden !important;
}

#displaybox {
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
    display: flex !important;
    flex-direction: column !important;
}

#gemini-cli-root {
    width: 100%;
    /* 240px offset should clear footer and headers perfectly */
    height: calc(100vh - 240px);
    min-height: 500px;
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
}

.gemini-cli-ui {
    height: 100%;
}
</style>

<script>
$(function(){
    // Ensure ttyd is active
    $.get('/plugins/unraid-geminicli/includes/GeminiSettings.php?action=start');
    
    // Continuous resize sync for the first 2 seconds to fix 8-line bug
    let count = 0;
    const interval = setInterval(function(){
        window.dispatchEvent(new Event('resize'));
        if (++count > 4) clearInterval(interval);
    }, 500);
});
</script>
