<style>
/* 
   SCORCHED EARTH on scrollbars. 
   We force hidden on EVERY potential parent wrapper.
*/
html,
body, 
#displaybox, 
#sb-body, 
.gemini-cli-ui, 
main, 
#main-content,
#gemini-cli-root,
.main-section {
    overflow: hidden !important;
    scrollbar-width: none !important; /* Firefox */
    -ms-overflow-style: none !important;  /* IE/Edge */
    margin: 0 !important;
    padding: 0 !important;
    box-sizing: border-box !important;
}

body::-webkit-scrollbar,
html::-webkit-scrollbar,
#displaybox::-webkit-scrollbar,
#sb-body::-webkit-scrollbar,
.gemini-cli-ui::-webkit-scrollbar,
main::-webkit-scrollbar,
#main-content::-webkit-scrollbar,
#gemini-cli-root::-webkit-scrollbar,
.main-section::-webkit-scrollbar {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
}

/* HIDE THE PAGE HEADER */
div.title, .title, .title-row, .title-bar, .header-row {
    display: none !important;
}

#displaybox {
    padding: 0 !important;
    margin-bottom: 0 !important;
    width: 100% !important;
    height: auto !important;
}

#main-content {
    padding: 0 !important;
    width: 100% !important;
    height: auto !important;
}

#gemini-cli-root {
    width: 100% !important;
    display: flex;
    flex-direction: column;
    margin: 0 !important;
    padding: 0 !important;
    /* Height is managed by JS to fill precisely to the footer */
    min-height: 400px;
    box-sizing: border-box !important;
    overflow: hidden !important;
}

.gemini-cli-ui {
    height: 100%;
    width: 100%;
    overflow: hidden !important;
}
</style>

<script>
$(function(){
    var resizeTimer;
    
    // THE NUCLEAR OPTION: Persistently kill scrollbars on the root containers
    function killScroll() {
        $('html, body, #displaybox, #sb-body, #main-content').css({
            'overflow': 'hidden',
            'height': 'auto',
            'max-height': '100vh'
        });
        document.documentElement.style.setProperty('overflow', 'hidden', 'important');
        document.body.style.setProperty('overflow', 'hidden', 'important');
    }

    // Dynamically size the root to fill from its top edge to the footer
    function resizeRoot() {
        if (resizeTimer) cancelAnimationFrame(resizeTimer);
        
        resizeTimer = requestAnimationFrame(function() {
            var el = document.getElementById('gemini-cli-root');
            if (!el) return;
            
            // Re-calculate top position to account for any dynamically injected Unraid banners
            var rect = el.getBoundingClientRect();
            
            // Try to find the Unraid footer
            var footer = document.getElementById('footer');
            var footerHeight = footer ? footer.offsetHeight : 24;
            if (!footerHeight || footerHeight < 10) footerHeight = 24; // Fallback
            
            // 20px safety gap: ensure we are always shorter than the viewport
            var padding = 20;
            var available = window.innerHeight - rect.top - footerHeight - padding;
            
            // Floor the height to avoid sub-pixel scaling causing 1px scrollbars
            var finalHeight = Math.floor(available);
            el.style.height = Math.max(400, finalHeight) + 'px';
            
            killScroll();
            
            // Force a resize event on the window to let the iframe know its container changed
            window.dispatchEvent(new Event('resize'));
        });
    }
    
    // Run on load, on resize, and after React mounts
    resizeRoot();
    window.addEventListener('resize', resizeRoot);
    
    // Multiple intervals to catch Unraid UI shifts
    [50, 150, 300, 600, 1200, 2500, 5000].forEach(ms => setTimeout(resizeRoot, ms));
    setInterval(killScroll, 1000);
});
</script>

