<script>
let currentPickerTarget = null;
let currentPickerPath = '/mnt';

function openPicker(targetId) {
    currentPickerTarget = targetId;
    const initialPath = document.getElementById(targetId).value || '/mnt';
    currentPickerPath = initialPath;
    
    document.getElementById('picker-modal').style.display = 'flex';
    browseTo(initialPath);
}

function closePicker() {
    document.getElementById('picker-modal').style.display = 'none';
}

function browseTo(path) {
    currentPickerPath = path;
    document.getElementById('picker-path').innerText = path;
    const list = document.getElementById('picker-list');
    list.innerHTML = '<div style="padding: 20px; text-align: center; opacity: 0.5;"><i class="fa fa-circle-o-notch fa-spin"></i> Reading...</div>';
    
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=list_dir&path=${encodeURIComponent(path)}&csrf_token=${window.csrf_token || ''}`)
        .then(r => r.json())
        .then(data => {
            list.innerHTML = '';
            
            // Add items
            data.items.forEach(item => {
                const div = document.createElement('div');
                div.className = 'aicli-modal-item';
                div.onclick = () => browseTo(item.path);
                
                const icon = item.name === '..' ? 'fa-level-up' : 'fa-folder';
                div.innerHTML = `<i class="fa ${icon}"></i> <span>${item.name}</span>`;
                list.appendChild(div);
            });
            
            if (data.items.length === 0) {
                list.innerHTML = '<div style="padding: 20px; text-align: center; opacity: 0.3;">Empty Directory</div>';
            }
        })
        .catch(err => {
            list.innerHTML = `<div style="padding: 20px; text-align: center; color: #ff5555;">Error: ${err.message}</div>`;
        });
}

function confirmSelection() {
    if (currentPickerTarget) {
        document.getElementById(currentPickerTarget).value = currentPickerPath;
    }
    closePicker();
}

function checkUpdates() {
    const btn = document.getElementById('btn-check-updates');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> Checking...';

    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=check_updates&csrf_token=${csrf}`)
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
            
            if (data.status === 'ok' && data.updates) {
                Object.entries(data.updates).forEach(([id, info]) => {
                    const status = document.getElementById(`status-${id}`);
                    if (status && info.has_update) {
                        status.className = 'agent-status update';
                        status.innerHTML = `<i class="fa fa-arrow-circle-up"></i> Update Available (${info.latest_version})`;
                    }
                });
            }
        })
        .catch(err => {
            console.error(err);
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
        });
}

function viewDebugLog() {
    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_log&csrf_token=${csrf}`)
        .then(r => r.text())
        .then(text => {
            if (typeof swal === 'function') {
                swal({
                    title: "Debug Log (Last 50 lines)",
                    text: text || "Log is empty.",
                    customClass: "swal-wide"
                });
            } else {
                alert(text);
            }
        });
}

function clearLog() {
    if (!confirm("Clear debug log?")) return;
    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=clear_log&csrf_token=${csrf}`)
        .then(r => r.json())
        .then(data => {
            if (data.status === 'ok') {
                if (typeof swal === 'function') swal("Log Cleared", "The debug log has been truncated.", "success");
                else alert("Log cleared");
            } else {
                alert("Failed to clear log: " + (data.message || 'Unknown error'));
            }
        });
}

let progressTimer = null;
function pollInstallStatus(agentId) {
    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_install_status&csrf_token=${csrf}`)
        .then(r => r.json())
        .then(data => {
            if (data.message) {
                const textEl = document.getElementById(`text-${agentId}`);
                const barEl = document.getElementById(`bar-${agentId}`);
                if (textEl) textEl.innerText = data.message;
                if (barEl) barEl.style.width = data.progress + '%';
            }
        });
}

function installAgent(agentId, isUpgrade = false) {
    if (isUpgrade && !confirm(`Upgrade ${agentId} to the latest version?`)) return;

    const status = document.getElementById(`status-${agentId}`);
    const progress = document.getElementById(`progress-${agentId}`);
    const bar = document.getElementById(`bar-${agentId}`);
    const text = document.getElementById(`text-${agentId}`);
    
    status.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> ' + (isUpgrade ? 'Upgrading...' : 'Installing...');
    progress.style.display = 'block';
    bar.style.width = '10%';
    if (text) text.innerText = 'Initializing...';

    // Start polling for granular status
    if (progressTimer) clearInterval(progressTimer);
    progressTimer = setInterval(() => pollInstallStatus(agentId), 800);

    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=install_agent&agentId=${agentId}&csrf_token=${csrf}`)
        .then(r => {
            if (!r.ok) {
                return r.text().then(txt => {
                    console.error('[AICli] Install Error (HTTP ' + r.status + '):', txt);
                    throw new Error('Server error: ' + r.status);
                });
            }
            return r.json();
        })
        .then(data => {
            clearInterval(progressTimer);
            if (data.status === 'ok') {
                bar.style.width = '100%';
                if (text) text.innerText = 'Success!';
                status.className = 'agent-status installed';
                status.innerHTML = '<i class="fa fa-check-circle"></i> ' + (isUpgrade ? 'Upgraded' : 'Installed');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                alert("Installation failed: " + (data.error || 'Unknown error'));
                status.innerHTML = 'Installation Failed';
                progress.style.display = 'none';
            }
        })
        .catch(err => {
            clearInterval(progressTimer);
            console.error(err);
            alert("Network error during installation. Check console for raw response.");
        });
}

function uninstallAgent(agentId) {
    if (!confirm(`Are you sure you want to uninstall ${agentId}?`)) return;
    
    const csrf = window.csrf_token || '';
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=uninstall_agent&agentId=${agentId}&csrf_token=${csrf}`)
        .then(r => r.json())
        .then(data => {
            if (data.status === 'ok') {
                window.location.reload();
            } else {
                alert("Uninstall failed: " + data.error);
            }
        });
}

function saveAICliAgentsManager(form, silent = false) {
    const formData = new FormData(form);
    const params = new URLSearchParams();
    
    // Deduplicate CSRF and other keys
    for (const [key, value] of formData.entries()) {
        params.set(key, value); 
    }
    
    // Ensure we use the latest system CSRF token if Dynamix has provided one
    const csrf = window.csrf_token || formData.get('csrf_token') || '';
    params.set('csrf_token', csrf);
    
    // D-18: Collect all preview checkboxes (they may be outside the main settings form)
    document.querySelectorAll('input[type="checkbox"][name^="preview_"]').forEach(cb => {
        params.set(cb.name, cb.checked ? "1" : "0");
    });
    
    console.log('[AICli] Saving settings (deduplicated):', params.toString());

    const performSave = (callback) => {
        fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=save&csrf_token=${csrf}`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: params.toString()
        })
        .then(r => {
            if (!r.ok) {
                return r.text().then(txt => {
                    console.error('[AICli] Server Error (HTTP ' + r.status + '):', txt);
                    throw new Error('Server returned ' + r.status);
                });
            }
            return r.json();
        })
        .then(data => {
            console.log('[AICli] Save response:', data);
            if (data.status === 'ok' && callback) callback();
            else if (data.status === 'ok' && !silent) {
                if (typeof swal === 'function') {
                    swal({
                        title: "Settings Saved",
                        text: "Changes applied. Some settings may require a terminal restart. Restart now?",
                        type: "success",
                        showCancelButton: true,
                        confirmButtonText: "Restart Terminal",
                        cancelButtonText: "Later"
                    }, function(confirmed) {
                        if (confirmed) {
                            fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=restart&csrf_token=${csrf}`)
                            .then(() => window.location.reload());
                        } else {
                            window.location.reload();
                        }
                    });
                } else {
                    window.location.reload();
                }
            } else if (data.status === 'ok' && silent) {
                window.location.reload();
            } else {
                alert("Save failed: " + (data.message || 'Unknown error'));
            }
        })
        .catch(err => {
            console.error("[AICli] Save Error:", err);
            alert("Settings failed to save. See console for raw server response.");
        });
    };

    // Check if home_path changed
    const oldHome = '<?=$config['home_path']?>';
    const newHome = formData.get('home_path');

    if (newHome && oldHome !== newHome) {
        if (typeof swal === 'function') {
            swal({
                title: "Home Directory Changed",
                text: "Would you like to move your existing agent data (history, config) to the new location?",
                type: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, Move Data",
                cancelButtonText: "No, Just Change Path",
                closeOnConfirm: false
            }, function(confirmed) {
                if (confirmed) {
                    // 1. Move data first
                    const moveParams = new URLSearchParams();
                    moveParams.append('old_path', oldHome);
                    moveParams.append('new_path', newHome);
                    moveParams.append('csrf_token', csrf);
                    
                    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=move_home&csrf_token=${csrf}`, {
                        method: 'POST',
                        body: moveParams
                    })
                    .then(r => r.json())
                    .then(moveData => {
                        if (moveData.status === 'ok') {
                            performSave(() => {
                                swal("Success", "Data moved and settings saved.", "success");
                                setTimeout(() => window.location.reload(), 1500);
                            });
                        } else {
                            swal("Error", "Failed to move data: " + moveData.message, "error");
                        }
                    });
                } else {
                    performSave();
                }
            });
            return;
        }
    }

    performSave();
}

// Auto-check for updates on page load
document.addEventListener('DOMContentLoaded', () => {
    setTimeout(checkUpdates, 1000);
});
</script>
