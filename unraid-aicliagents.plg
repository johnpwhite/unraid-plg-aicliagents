<!-- MAIN INSTALL ENGINE -->
<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
# AICliAgents Modular Installer Engine
export NAME="unraid-aicliagents"
export VERSION="2026.06.07.02"
export GIT_URL="https://raw.githubusercontent.com/johnpwhite/unraid-plg-aicliagents/main"
export EMHTTP_DEST="/usr/local/emhttp/plugins/unraid-aicliagents"
export CONFIG_DIR="/boot/config/plugins/unraid-aicliagents"

# --- I/O Setup (FD 1 = Log, FD 3 = Progress, FD 4 = UI) ---
# D-194: Redirect original STDOUT to FD 4 before redirecting FD 1 to log file
exec 4&gt;&amp;1

# D-347: Detection of Upgrade vs Fresh Install
export UPGRADE_MODE="0"
if [ -d "$EMHTTP_DEST" ] || [ -f "/var/log/plugins/$NAME.plg" ]; then
    export UPGRADE_MODE="1"
fi

# WP #941: Snapshot the currently-installed layout-version BEFORE the engine
# extracts the new src/ tarball (which would otherwise overwrite it). cleanup.sh
# compares this to the new on-disk value to decide hot-swap vs scorched-earth.
# Default "0" handles fresh installs and pre-#941 versions (which never wrote
# this file) — both correctly flag as a layout change on the very first upgrade.
# M4 fix (v2026.05.18.08): strip whitespace + validate as integer. An
# empty/whitespace/non-numeric file would otherwise yield "" which fails
# the `!= "0"` test and trips a spurious scorched-earth teardown.
_OLD_LV_RAW="$(cat "$EMHTTP_DEST/src/.layout-version" 2&gt;/dev/null || true)"
_OLD_LV="$(printf '%s' "$_OLD_LV_RAW" | tr -d '[:space:]')"
[ -z "$_OLD_LV" ] &amp;&amp; _OLD_LV="0"
[[ "$_OLD_LV" =~ ^[0-9]+$ ]] || _OLD_LV="0"
export OLD_LAYOUT_VERSION="$_OLD_LV"

# OP #429: Clean orphan name-new.plg files left behind by prior aborted
# installs. Unraid's plugin manager downloads updates to name-new.plg, runs
# install, and atomic-renames -new.plg to .plg on success. Any abort before
# the rename (e.g. the FD 4 hang fixed in OP #419) strands the -new.plg, and
# Unraid's UI then renders a duplicate plugin row indefinitely.
# Conservative: only remove -new.plg if its embedded version is OLDER than
# our currently-installing version. Never touches a -new.plg whose version is
# newer than ours (could be a real in-flight install we're racing).
for _orphan in "/boot/config/plugins/${NAME}-new.plg"; do
    [ -f "$_orphan" ] || continue
    _orphan_ver=$(grep -oP '&lt;!ENTITY version\s+"[^"]+"' "$_orphan" 2>/dev/null | grep -oP '"[^"]+"' | tr -d '"' | head -1)
    if [ -n "$_orphan_ver" ] &amp;&amp; [ "$_orphan_ver" != "2026.06.07.02" ]; then
        # Sort: if orphan_ver lex-sorts BEFORE our version, orphan is older — safe to remove.
        _newest=$(printf '%s\n%s\n' "$_orphan_ver" "2026.06.07.02" | sort -V | tail -1)
        if [ "$_newest" = "2026.06.07.02" ]; then
            rm -f "$_orphan" "/var/log/plugins/${NAME}-new.plg" 2>/dev/null || true
            echo "[$(date '+%Y-%m-%d %H:%M:%S')] [AICliAgents] INFO: Removed orphan ${NAME}-new.plg ($_orphan_ver, older than 2026.06.07.02)" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null || true
        fi
    fi
done

# D-230: Define authoritative logging helpers (Aligned with LogService.php)
get_ts() { date '+%Y-%m-%d %H:%M:%S'; }
log_status() { echo "$1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO: $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_step()   { echo "" &gt;&amp;4 2&gt;/dev/null; echo "  [>] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO:   [>] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_ok()     { echo "  [OK] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO:   [OK] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_warn()   { echo "  [!!] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] WARN:   [!!] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_fail()   { echo "  [FAIL] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] ERROR:   [FAIL] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_progress() { echo "PROGRESS: $1" &gt;&amp;3 2&gt;/dev/null; }

export -f log_status log_step log_ok log_warn log_fail log_progress get_ts

chmod +x /tmp/aicli-*.sh

mkdir -p /tmp/unraid-aicliagents "$CONFIG_DIR"
LOG_FILE="$CONFIG_DIR/install.log"
export LOG_FILE

# Clear old log and start with a header
echo "[$(get_ts)] [AICliAgents] INFO: --- AICliAgents Installation Log (v$VERSION) ---" &gt; "$LOG_FILE"

# --- Modular Engine Bootstrap ---
# We run the engine in a subshell and pipe its entire output (traces/errors) 
# into a timestamp formatter for the log file.
if [ -f "/tmp/aicli-engine.sh" ]; then
    (
        set -x
        bash /tmp/aicli-engine.sh
    ) 2&gt;&amp;1 | while read -r line; do
        # If it's a progress signal, send to FD 3
        if [[ "$line" == PROGRESS:* ]]; then
            echo "$line" &gt;&amp;3 2&gt;/dev/null
        # D-291: Standard Timestamp Regex [YYYY-MM-DD HH:MM:SS]
        elif [[ "$line" =~ ^\[[0-9]{4}-[0-9]{2}-[0-9]{2}\ [0-9]{2}:[0-9]{2}:[0-9]{2}\] ]]; then
            echo "$line" &gt;&gt; "$LOG_FILE"
        else
            echo "[$(get_ts)] [AICliAgents] INFO: $line" &gt;&gt; "$LOG_FILE"
        fi
    done
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        log_fail "Modular Engine execution failed. Aborting installation."
        exit 1
    fi
else
    log_fail "Installer Engine (aicli-engine.sh) missing from /tmp. Aborting."
    exit 1
fi

# Phase 6: Storage Migration (Background)
# D-308: Moved OUTSIDE subshell/pipe to prevent installer hang.
# Full detachment ensured with &lt; /dev/null
if [ -f /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/installer/migrate-btrfs-to-squashfs.sh ]; then
    log_status "Initiating background storage migration (Btrfs -&gt; SquashFS)..."
    mkdir -p /tmp/unraid-aicliagents
    touch /tmp/unraid-aicliagents/migration.lock
    nohup bash /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/installer/migrate-btrfs-to-squashfs.sh &gt; /tmp/unraid-aicliagents/migration.log 2&gt;&amp;1 &lt; /dev/null 4&gt;&amp;- &amp;
    disown
fi

# Phase 3: Start the Storage Durability Supervisor daemon.
# Full daemonisation: setsid creates a new session ID so the supervisor is
# detached from the installer's controlling TTY. nohup + disown is not enough
# over SSH — descriptors stay coupled to the session and the SSH wrapper
# hangs at session-exit waiting for the supervisor's heartbeat loop. setsid
# severs the link cleanly so plugin install returns immediately.
# 4&gt;&amp;- closes the installer progress pipe FD so PHP installer can exit at boot
# (rc.local installs don't use SSH TTY but still inherit non-stdio FDs).
if [ -f /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/supervisor/aicli-supervisor.sh ]; then
    # Defensive stop-and-wait: cleanup.sh stops the old supervisor at the start
    # of the upgrade, but if cleanup was skipped (fresh install) or the old
    # supervisor respawned mid-install via the lazy backstop, ensure no
    # instance is alive before launching. Otherwise the new supervisor's
    # _pidfile_valid check sees the old PID and bails silently.
    if [ -f /var/run/aicli-supervisor.pid ]; then
        _OLD_SUP_PID=$(cat /var/run/aicli-supervisor.pid 2&gt;/dev/null || echo "")
        if [ -n "$_OLD_SUP_PID" ] &amp;&amp; kill -0 "$_OLD_SUP_PID" 2&gt;/dev/null; then
            log_status "Old supervisor (pid $_OLD_SUP_PID) still alive — stopping before launch..."
            bash /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/supervisor/aicli-supervisor.sh stop &gt;/dev/null 2&gt;&amp;1 || true
            for _i in $(seq 1 15); do
                kill -0 "$_OLD_SUP_PID" 2&gt;/dev/null || break
                sleep 1
            done
            if kill -0 "$_OLD_SUP_PID" 2&gt;/dev/null; then
                kill -9 "$_OLD_SUP_PID" 2&gt;/dev/null || true
                rm -f /var/run/aicli-supervisor.pid 2&gt;/dev/null || true
            fi
        elif [ -n "$_OLD_SUP_PID" ]; then
            rm -f /var/run/aicli-supervisor.pid 2&gt;/dev/null || true
        fi
    fi

    # Bug 513 / 578 orphan supervisor sweep. Pattern includes " start" so the
    # pgrep matches ONLY the long-running daemon subcommand and skips one-shot
    # CLI invocations (cleanup-phantoms / status / stop) that may be running
    # concurrently — those used to add 5+ s to the reap window for nothing.
    _ORPHAN_PIDS=$(pgrep -f "/usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/supervisor/aicli-supervisor.sh start" 2&gt;/dev/null | grep -v "^$$\$" || true)
    if [ -n "$_ORPHAN_PIDS" ]; then
        log_status "Orphan supervisor process detected — terminating before launch"
        echo "$_ORPHAN_PIDS" | xargs -r kill -15 2&gt;/dev/null || true
        sleep 2
        _ORPHAN_PIDS=$(pgrep -f "/usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/supervisor/aicli-supervisor.sh start" 2&gt;/dev/null | grep -v "^$$\$" || true)
        if [ -n "$_ORPHAN_PIDS" ]; then
            echo "$_ORPHAN_PIDS" | xargs -r kill -9 2&gt;/dev/null || true
        fi
        rm -f /var/run/aicli-supervisor.pid 2&gt;/dev/null || true
    fi

    log_status "Starting storage durability supervisor..."
    mkdir -p /tmp/unraid-aicliagents
    setsid nohup bash /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/supervisor/aicli-supervisor.sh start &gt;/tmp/unraid-aicliagents/supervisor.log 2&gt;&amp;1 &lt;/dev/null 4&gt;&amp;- &amp;
    disown
fi

# Fix B: Populate the available-version cache for ALL agents (installed AND
# uninstalled) on every install/upgrade. Without this, Store cards for
# uninstalled agents show "vunknown available" until the user clicks
# "Check for Updates" or the daily 06:00 cron fires. version-check-bg.php
# holds an advisory flock so concurrent calls are safe (extras return cached
# results immediately without racing). setsid+nohup+4&gt;&amp;- so this never
# blocks the installer regardless of invocation method (SSH, rc.local, UI).
if [ -f /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/version-check-bg.php ]; then
    log_status "Running background agent version-cache refresh..."
    setsid nohup /usr/bin/php /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/version-check-bg.php &gt;/tmp/unraid-aicliagents/version-check.log 2&gt;&amp;1 &lt;/dev/null 4&gt;&amp;- &amp;
    disown
fi

# Bug 521 - autolaunch sweep on plugin upgrade. Sessions were evicted by
# cleanup.sh at the start of the upgrade; flagged workspaces should resume
# in the background BEFORE the user opens the tab. setsid+nohup so this
# never blocks the installer; 4 close prevents any inherited progress pipe
# from holding the install hostage.
if [ -f /usr/local/emhttp/plugins/unraid-aicliagents/src/includes/AICliAgentsManager.php ]; then
    log_status "Running auto-launch sweep for flagged workspaces..."
    setsid nohup /usr/bin/php -r "
        require_once '/usr/local/emhttp/plugins/unraid-aicliagents/src/includes/AICliAgentsManager.php';
        \AICliAgents\Services\AutoLaunchService::launchAllPending(null, 'plugin_upgrade');
    " &gt;&gt;/tmp/unraid-aicliagents/debug.log 2&gt;&amp;1 &lt;/dev/null 4&gt;&amp;- &amp;
    disown

    # Backfill versions.json for installed agents stuck at the 0.0.0 sentinel.
    # 2026-05-09 production bug: agents installed by older plugin versions, or
    # with overlay unmounted at the time of last getRegistry call, were stuck
    # at version=0.0.0 forever (10 of 11 agents on John's box).
    #
    # SYNCHRONOUS rather than detached: smoke A108 runs immediately after the
    # PLG completes and asserts no installed agent is at the sentinel version.
    # Detaching would race the smoke. Per-agent mount+read+unmount in series
    # is acceptable on upgrade.
    log_status "Backfilling missing agent versions..."
    /usr/bin/php -r "
        require_once '/usr/local/emhttp/plugins/unraid-aicliagents/src/includes/AICliAgentsManager.php';
        \$r = \AICliAgents\Services\AgentRegistry::recoverMissingVersions();
        aicli_log('recoverMissingVersions: recovered=' . \$r['recovered'] . ' skipped=' . \$r['skipped'] . ' failed=' . implode(',', \$r['failed']), AICLI_LOG_INFO, 'PLG_INLINE');
        echo \"recovered={\$r['recovered']} skipped={\$r['skipped']} failed=\" . implode(',', \$r['failed']) . PHP_EOL;
    " 2&gt;&amp;1 | tee -a /tmp/unraid-aicliagents/debug.log

    # WP #736: seed manifest-declared default_envs into every installed agent's
    # general-env store. Additive only — never overwrites a user value, never
    # auto-removes, honours user deletions via the seeded sidecar. Each plugin
    # upgrade picks up any newly-declared defaults (e.g. the first ship of this
    # feature seeds GEMINI_CLI_ENABLE_AUTO_UPDATE=false for installed gemini-cli).
    log_status "Seeding agent default envs..."
    /usr/bin/php -r "
        require_once '/usr/local/emhttp/plugins/unraid-aicliagents/src/includes/AICliAgentsManager.php';
        \$s = \AICliAgents\Services\EnvService::seedAllInstalledAgentDefaults();
        \$touched = implode(',', \$s['agents_touched']);
        aicli_log('seedAllInstalledAgentDefaults: agents=' . \$s['agents'] . ' seeded_total=' . \$s['seeded_total'] . ' agents_touched=' . \$touched, AICLI_LOG_INFO, 'PLG_INLINE');
        echo \"seed: agents={\$s['agents']} seeded_total={\$s['seeded_total']} touched={\$touched}\" . PHP_EOL;
    " 2&gt;&amp;1 | tee -a /tmp/unraid-aicliagents/debug.log

    # WP #748 Phase 1 (A/B/C): migrate cadence defaults for existing installs.
    # Existing .cfg files have the OLD defaults written into them literally, so
    # changing ConfigService defaults alone is a no-op for those users. For each
    # key: if the stored value equals the OLD default exactly, rewrite it to the
    # NEW default. If the user customised it (value differs from both old AND new),
    # leave it untouched. Uses ConfigService::saveConfig for atomic, safe writes.
    log_status "Migrating Flash-wear cadence defaults (WP #748)..."
    /usr/bin/php -r "
        require_once '/usr/local/emhttp/plugins/unraid-aicliagents/src/includes/AICliAgentsManager.php';
        \$cfg = \AICliAgents\Services\ConfigService::getConfig();
        \$migrations = [
            'bake_schedule_minutes'             =&gt; ['old' =&gt; '30',   'new' =&gt; '120'],
            'dirty_threshold_soft_mb'           =&gt; ['old' =&gt; '512',  'new' =&gt; '1024'],
            'dirty_threshold_hard_mb'           =&gt; ['old' =&gt; '1024', 'new' =&gt; '2048'],
            'dirty_threshold_critical_mb'       =&gt; ['old' =&gt; '2048', 'new' =&gt; '4096'],
            'consolidate_layer_threshold_flash' =&gt; ['old' =&gt; '15',   'new' =&gt; '30'],
        ];
        \$updates = [];
        foreach (\$migrations as \$key =&gt; \$m) {
            \$stored = (string)(\$cfg[\$key] ?? '');
            if (\$stored === \$m['old']) {
                \$updates[\$key] = \$m['new'];
                aicli_log(\"cfg-migrate: \$key \$stored -&gt; {\$m['new']} (was old default)\", AICLI_LOG_INFO, 'PLG_INLINE');
            } elseif (\$stored === \$m['new']) {
                aicli_log(\"cfg-migrate: \$key already at new default {\$m['new']} — skip\", AICLI_LOG_INFO, 'PLG_INLINE');
            } else {
                aicli_log(\"cfg-migrate: \$key=\$stored is user-customised — skip\", AICLI_LOG_INFO, 'PLG_INLINE');
            }
        }
        if (!empty(\$updates)) {
            \AICliAgents\Services\ConfigService::saveConfig(\$updates, false);
            echo 'cfg-migrate: updated ' . implode(', ', array_keys(\$updates)) . PHP_EOL;
        } else {
            echo 'cfg-migrate: nothing to update' . PHP_EOL;
        }
    " 2&gt;&amp;1 | tee -a /tmp/unraid-aicliagents/debug.log
fi
    # NOTE (2026-05-12, Fix #1): WP #748 Phase 1 (F) originally enqueued a home consolidate
    # (reason=wear_cleanup) here so cache junk in lower layers would be shed promptly.
    # REVERTED: on the test box a consolidate triggered during the chaotic post-deploy window
    # (multiple supervisor instances spawning simultaneously) got SIGTERM'd mid-flight, after
    # deleting the old layer files but before updating the manifest, corrupting the manifest.
    # The accumulated cache junk is shed at the next NATURAL consolidate instead —
    # consolidate_layers.sh already has the home-overlay prune from WP #748 F. The
    # prune-on-natural-consolidate path is safe; a forced-on-upgrade consolidate is not.

# Cleanup ALL staged installer artifacts from /tmp — scripts, .page files,
# src.tar.gz. Previous versions only rm'd *.sh, which meant /tmp/aicli-stop-
# warning.page and /tmp/aicli-src.tar.gz persisted across installs and triggered
# plugin-manager "skipping: already exists" log lines on every subsequent
# install. The skip isn't fatal but it means stale staged content can silently
# survive an upgrade. Broad glob keeps /tmp clean.
rm -f /tmp/aicli-*.sh /tmp/aicli-*.page /tmp/aicli-src.tar.gz

</INLINE>
</FILE>

<!-- UNINSTALL ENGINE -->
<FILE Method="remove" Run="/bin/bash">
<INLINE>
#!/bin/bash
NAME="unraid-aicliagents"
CONFIG_DIR="/boot/config/plugins/$NAME"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"

# 1. Setup Logging &amp; Status
# We log to USB for persistence during uninstall
LOG_FILE="$CONFIG_DIR/uninstall.log"
exec 3&gt;&amp;1
exec &gt; "$LOG_FILE" 2&gt;&amp;1
set -x

log_status() { echo "$1" &gt;&amp;3; }
export -f log_status

log_status "--- AICliAgents Uninstall Start ---"

# 1.A PERSISTENCE PHASE (MANDATORY for Upgrades)
# D-341: Ensure all ZRAM-backed user homes are persisted before we kill the processes.
# D-344: Architecture-Aware Persistence. We check for new TaskService first, then fallback to legacy procedural sync.
log_status "Persisting active user states from RAM/ZRAM to Flash..."
if [ -f "$EMHTTP_DEST/src/includes/AICliAgentsManager.php" ]; then
    for user_mnt in /tmp/unraid-aicliagents/work/*/home; do
        if mountpoint -q "$user_mnt"; then
            user=$(basename "$(dirname "$user_mnt")")
            log_status "  &gt; Detected active SquashFS home for $user..."
            
            # 1. Check for TaskService (Modern 2026.04+)
            if grep -q "TaskService" "$EMHTTP_DEST/src/includes/AICliAgentsManager.php"; then
                log_status "    &gt; Using TaskService::persistHome..."
                /usr/bin/php -r "require_once '$EMHTTP_DEST/src/includes/AICliAgentsManager.php'; \AICliAgents\Services\TaskService::persistHome('$user', true);" &gt; /dev/null 2&gt;&amp;1
            
            # 2. Check for legacy procedural sync (Early 2026)
            elif grep -q "function aicli_sync_home" "$EMHTTP_DEST/src/includes/AICliAgentsManager.php"; then
                log_status "    &gt; Using legacy aicli_sync_home..."
                /usr/bin/php -r "require_once '$EMHTTP_DEST/src/includes/AICliAgentsManager.php'; aicli_sync_home('$user');" &gt; /dev/null 2&gt;&amp;1
            fi
        fi
    done
fi

# D-345: Legacy IMG Persistence (Era 2)
# If legacy .img files are mounted, they are Btrfs loop mounts and typically 
# handled by 'umount', but we ensure any known RAM shims are flushed if applicable.
# (Most Era 2 plugins synced on every write, but we perform a safety sync)
if mount | grep -q "aicliagents.*\.img"; then
    log_status "  &gt; Flushing legacy Btrfs loop mounts..."
    sync
fi

# 2. Kill Active Processes &amp; Runtime Files
# We call the modular script for the heavy lifting of process killing. Path
# corrected: the file lives under src/scripts/uninstaller, not scripts/uninstaller.
# The old wrong path caused the unsafe fallback below to run on EVERY plugin
# upgrade — which killed a users DevBox VM (its qemu cmdline contained
# "gemini" as a substring and matched the old broad regex).
UNINSTALL_SCRIPT="$EMHTTP_DEST/src/scripts/uninstaller/cleanup.sh"
if [ -f "$UNINSTALL_SCRIPT" ]; then
    export NAME EMHTTP_DEST CONFIG_DIR
    bash "$UNINSTALL_SCRIPT"
else
    # Fallback if script missing. Hardened so it can NEVER kill a VM/libvirt
    # process even if its cmdline happens to share a substring with one of our
    # patterns. Two protections: (a) kill patterns are anchored to plugin-owned
    # paths so they cannot match qemu/libvirt cmdlines, (b) an exe-path filter
    # drops any pid whose /proc/PID/exe is under qemu/libvirt/kvm/init.
    log_status "Cleaning up active processes..."
    _fb_safe_kill() {
        local pattern="$1"
        local pid exe
        for pid in $(pgrep -f "$pattern" 2&gt;/dev/null | grep -v "$$" || true); do
            exe=$(readlink "/proc/$pid/exe" 2&gt;/dev/null)
            case "$exe" in
                */qemu*|*/libvirt*|*/virsh|*/kvm|*/systemd|*/init|/sbin/init) continue ;;
            esac
            kill -9 "$pid" &gt;/dev/null 2&gt;&amp;1 || true
        done
    }
    _fb_safe_kill 'ttyd.*aicliterm-'
    if command -v tmux &gt;/dev/null 2&gt;&amp;1; then
        tmux ls -F '#S' 2&gt;/dev/null | grep -E "^aicli-agent-" | xargs -I {} tmux kill-session -t "{}" &gt; /dev/null 2&gt;&amp;1 || true
    fi
    _fb_safe_kill 'node .*(unraid-aicliagents|/\.aicli/)'
fi

# MANDATORY: Clear stale installation states and runtime logs
rm -rf /tmp/unraid-aicliagents

# 3. Prune USB Artifacts (pkg-cache removal as requested)
if [ -d "$CONFIG_DIR" ]; then
    log_status "Pruning USB artifacts..."
    rm -f "$CONFIG_DIR/aicli.mjs"
    rm -f "$CONFIG_DIR/debug.log"
    rm -f "$CONFIG_DIR/versions.json"
    rm -f "$CONFIG_DIR/tmux"
    rm -f "$CONFIG_DIR"/*.tar.gz
    rm -f "$CONFIG_DIR"/*.tar.xz
    rm -f "$CONFIG_DIR"/*.gz
    # MANDATORY: Remove agent package caches
    rm -rf "$CONFIG_DIR/pkg-cache"
fi

# 4. Forced emhttp removal (Ensures tab disappears)
if [ -d "$EMHTTP_DEST" ]; then
    log_status "Removing plugin files from emhttp..."
    rm -f /usr/local/bin/aicli-repair
    rm -rf "$EMHTTP_DEST"
fi

# 5. Final PLG clean
rm -f /var/log/plugins/${NAME}.plg

log_status " "
log_status "==========================================================="
log_status "                UNINSTALL COMPLETE                        "
log_status "==========================================================="
log_status " "
log_status "  [DONE] Binaries and UI files removed"
log_status "  [DONE] Runtime processes terminated"
log_status "  [DONE] Agent package caches pruned"
log_status " "
log_status "  [NOTE] YOUR SETTINGS HAVE BEEN PRESERVED:"
log_status "  &gt; Config:     $CONFIG_DIR/*.cfg"
log_status "  &gt; Persistence: $CONFIG_DIR/persistence/"
log_status " "
log_status "  [LOGS] Detailed uninstall trace preserved at:"
log_status "  &gt; $LOG_FILE"
log_status " "
log_status "  [TIP] To fully remove all data, manually delete:"
log_status "  &gt; rm -rf $CONFIG_DIR"
log_status "==========================================================="

echo "Uninstall of $NAME complete."
exit 0
</INLINE>
</FILE>

</PLUGIN>
