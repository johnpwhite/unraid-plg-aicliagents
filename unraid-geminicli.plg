<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
<!ENTITY name      "unraid-geminicli">
<!ENTITY author    "John White">
<!ENTITY version   "2026.02.25.09">
<!ENTITY launch    "Settings/GeminiCLI">
<!ENTITY gitURL    "https://gitlab.johnpwhite.com/johner/unraid-plg-geminicli/-/raw/master">
<!ENTITY pluginURL "https://gitlab.johnpwhite.com/johner/unraid-plg-geminicli/-/raw/master/unraid-geminicli.plg">
<!ENTITY boot      "/boot/config/plugins/unraid-geminicli">
<!ENTITY emhttp    "/usr/local/emhttp/plugins/unraid-geminicli">
]>
<PLUGIN name="unraid-geminicli" author="John White" version="2026.02.25.09" launch="Settings/GeminiCLI" pluginURL="https://gitlab.johnpwhite.com/johner/unraid-plg-geminicli/-/raw/master/unraid-geminicli.plg" min="7.2.0">

<CHANGES>
## 2026.02.25.09
- Fix: Standardized terminal using standard Unraid Nginx proxy and iframe for better compatibility.
## 2026.02.25.08
- Fix: Switched to standard Unraid Nginx proxy (/webterminal/geminiterm/) using &lt;iframe&gt;.
- Optimized UI assets and fixed ttyd startup parameters.
## 2026.02.25.07
- Fix: Manual version alignment for XML safety.
## 2026.02.25.06
- Fix: Simplify shell script (remove tmux) and ttyd startup logic to troubleshoot silent terminal failure.
- Unified logging to /tmp/ttyd-gemini.log and /tmp/gemini-shell.log.
## 2026.02.25.05
- Fix: Enhanced terminal logging and permission management for shell and ttyd.
- Redirecting shell logs to /tmp/gemini-shell.log for debugging.
## 2026.02.25.04
- Feat: Integrated portable Node.js v20.11.0.
- Improved ttyd protocol handling (input fix).
- Added robust shell logging and tmux fallback.
## 2026.02.25.03
- Feat: Terminal UI overhaul.
- Added toolbar (font size, themes), FitAddon scaling, and ttyd protocol fix for interactive input.
## 2026.02.25.02
- Fix: Wrap shell scripts in CDATA to resolve XML parse errors during installation.
## 2026.02.25.01
- Initial release of Unraid Gemini CLI plugin structure.
- Integrated gemini-cli v0.30.0-preview.5.
- Restricted terminal environment in /mnt.
</CHANGES>

<!-- 1. INSTALLER SCRIPT -->
<FILE Run="/bin/bash" Name="/tmp/unraid-geminicli-installer">
<INLINE>
<![CDATA[
#!/bin/bash
NAME="unraid-geminicli"
GIT_URL="https://gitlab.johnpwhite.com/johner/unraid-plg-geminicli/-/raw/master"
GEMINI_JS_URL="https://github.com/google-gemini/gemini-cli/releases/download/v0.30.0-preview.5/gemini.js"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"
CONFIG_DIR="/boot/config/plugins/$NAME"

echo "--- INSTALL START ---"
rm -rf "$EMHTTP_DEST"
mkdir -p "$EMHTTP_DEST"
mkdir -p "$CONFIG_DIR/bin"

# 1. Download gemini.js
echo "Downloading gemini.js v0.30.0-preview.5..."
wget -q -O "$CONFIG_DIR/bin/gemini.js" "$GEMINI_JS_URL"

# 2. Download Portable Node.js (v20.11.0)
if [ ! -x "$CONFIG_DIR/bin/node" ]; then
    echo "Downloading portable Node.js (v20.11.0)..."
    NODE_TAR="node-v20.11.0-linux-x64.tar.xz"
    NODE_URL="https://nodejs.org/dist/v20.11.0/$NODE_TAR"
    wget -q -O "/tmp/$NODE_TAR" "$NODE_URL"
    if [ $? -eq 0 ]; then
        echo "Extracting Node.js..."
        tar -xJf "/tmp/$NODE_TAR" -C "$CONFIG_DIR/bin" --strip-components=2 "node-v20.11.0-linux-x64/bin/node"
        rm "/tmp/$NODE_TAR"
    else
        echo "ERROR: Failed to download Node.js"
    fi
fi

# 3. Create gemini wrapper
cat << 'EOF' > /usr/local/bin/gemini
#!/bin/bash
BIN_DIR="/boot/config/plugins/unraid-geminicli/bin"
# Ensure we use our portable node
"$BIN_DIR/node" "$BIN_DIR/gemini.js" "$@"
EOF
chmod +x /usr/local/bin/gemini

# 4. Setup Directories
mkdir -p "$EMHTTP_DEST/scripts"

# 4. Download/Install Plugin Files
download_file() {
    local src=$1
    local dest=$2
    local dir=$(dirname "$EMHTTP_DEST/$dest")
    mkdir -p "$dir"
    wget -q -O "$EMHTTP_DEST/$dest" "$GIT_URL/$src"
    # Force LF line endings for all scripts and .page files
    if [[ "$dest" == *.sh || "$dest" == *.php || "$dest" == *.page ]]; then
        tr -d '\r' < "$EMHTTP_DEST/$dest" > "$EMHTTP_DEST/$dest.tmp" &amp;&amp; mv "$EMHTTP_DEST/$dest.tmp" "$EMHTTP_DEST/$dest"
    fi
}

download_file "src/scripts/gemini-shell.sh" "scripts/gemini-shell.sh"
chmod +x "$EMHTTP_DEST/scripts/gemini-shell.sh"

download_file "src/GeminiCLI.page" "GeminiCLI.page"
download_file "src/includes/GeminiSettings.php" "includes/GeminiSettings.php"
download_file "src/assets/ui/index.js" "assets/ui/index.js"
download_file "src/assets/ui/index.css" "assets/ui/index.css"
download_file "src/gemini-cli.png" "gemini-cli.png"
download_file "src/README.md" "README.md"

echo "--- INSTALL COMPLETE ---"
rm /tmp/unraid-geminicli-installer
]]>
</INLINE>
</FILE>

<!-- 2. REMOVE -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
#!/bin/bash
NAME="unraid-geminicli"
PLUGIN_DIR="/usr/local/emhttp/plugins/$NAME"
CONFIG_DIR="/boot/config/plugins/$NAME"
echo "Removing $NAME..."
rm -rf "$PLUGIN_DIR"
rm -rf "$CONFIG_DIR"
removepkg "$NAME" > /dev/null 2>&amp;1
echo "Uninstall of $NAME complete."
exit 0
]]>
</INLINE>
</FILE>

</PLUGIN>
