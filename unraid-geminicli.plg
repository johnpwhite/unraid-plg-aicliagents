<?xml version='1.0' standalone='yes'?>

<PLUGIN name="unraid-geminicli" author="John White" version="2026.03.02.17" launch="Settings/GeminiSettings" pluginURL="https://github.com.com/johnpwhite/unraid-plg-geminicli/raw/main/unraid-geminicli.plg" min="7.2.0" icon="unraid-geminicli.png">

<CHANGES>
## v2026.03.02.17

- **Metadata Overlay**: Hover over any workspace tab to see its full filesystem path and active Gemini Session ID.
- **Session Reset**: Added a manual "RESET" button to the tab overlay to clear stuck sessions or start fresh conversations.
- **Smart Workspace Isolation**: Robust project detection that ensures nested folders correctly maintain their own independent Gemini sessions.
- **Reliable Session Resumption**: Significant improvements to session recovery across server reboots and browser refreshes.
- **Cleaner Tab Labels**: Redesigned tab titles that prioritize the workspace folder name and ONLY show status emojis (◇, ✦, ✋) when active.
- **Polished Terminal UI**: Added a balanced 8px padding around the terminal with rounded corners and transparent background for better theme integration.
- **Eliminated Scrollbars**: Implemented persistent suppression of internal and external scrollbars for a cleaner, full-screen terminal experience.
- **Dependency Upgrades**: Upgraded to the latest stable versions of Gemini CLI (v0.31.0), Node.js (v22.22.0 LTS), and tmux (v3.6a).
- **Improved Security**: Added CSRF validation for all state-changing AJAX actions.

### v2026.02.27.20 - Initial Release: Key Features

- **Native AI Integration**: Direct integration of Google Gemini into the Unraid WebUI, providing a powerful AI agent for server management and coding tasks.
- **Multi-Workspace Terminal**: Support for multiple terminal sessions (Workspaces). Open different folders in separate tabs to manage various projects simultaneously.
- **Dynamic Status Tracking**: Tabs poll terminal state in real-time, displaying Gemini's status icons (Ready ◇, Working ✦, Action Required ✋) and active task descriptions.
- **Integrated File Browser**: Seamlessly navigate your server's filesystem to select and open new workspaces.
- **Responsive Terminal Design**: A modern, high-performance terminal wrapper with dynamic resizing that automatically fills available screen space and fits perfectly above the footer.
- **Unraid Theme Integration**: Harmonious UI design that matches your Unraid theme (Light/Dark) and respects standard system variables.
- **Smart Session Management**: Persistent terminal sessions that remain active in the background, allowing you to switch between tasks without losing state.
</CHANGES>

<!-- 1. INSTALLER SCRIPT -->
<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
set -e
NAME="unraid-geminicli"
VERSION="2026.03.02.17"
GIT_URL="https://github.com/johnpwhite/unraid-plg-geminicli/raw/main"
GEMINI_JS_URL="https://github.com/google-gemini/gemini-cli/releases/download/v0.31.0/gemini.js"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"
CONFIG_DIR="/boot/config/plugins/$NAME"

echo "--- INSTALL START ---"
# Force cleanup of any old processes during install to ensure clean state
echo "Cleaning up existing processes..."
ps -ef | grep geminiterm.sock | grep -v grep | awk '{print $2}' | xargs kill -9 > /dev/null 2>&amp;1 || true
tmux kill-session -t gemini-cli > /dev/null 2>&amp;1 || true
rm -f /var/run/geminiterm.sock
rm -f /var/run/unraid-geminicli.pid

# Aggressive cleanup of ALL previous assets to ensure fresh load
rm -rf "$EMHTTP_DEST"
mkdir -p "$EMHTTP_DEST/bin"
mkdir -p "$EMHTTP_DEST/scripts"
mkdir -p "$CONFIG_DIR"

# 1. Download gemini.js to /boot (persistence)
echo "Downloading gemini.mjs (v0.31.0)..."
wget -q -O "$CONFIG_DIR/gemini.mjs" "$GEMINI_JS_URL?v=$VERSION"
# Copy to RAM for execution
cp "$CONFIG_DIR/gemini.mjs" "$EMHTTP_DEST/bin/gemini.mjs"

# 2. Download/Extract Portable Node.js (v22.22.0)
NODE_TAR="node-v22.22.0-linux-x64.tar.xz"
NODE_URL="https://nodejs.org/dist/v22.22.0/$NODE_TAR"

if [ ! -f "$CONFIG_DIR/$NODE_TAR" ]; then
    echo "Downloading portable Node.js (v22.22.0)..."
    wget -q -O "$CONFIG_DIR/$NODE_TAR" "$NODE_URL"
else
    echo "Using cached Node.js (v22.22.0)..."
fi

echo "Extracting Node.js binary..."
TMP_EXTRACT="/tmp/node-extract-$$"
mkdir -p "$TMP_EXTRACT"
tar -xf "$CONFIG_DIR/$NODE_TAR" -C "$TMP_EXTRACT"

NODE_BIN=$(find "$TMP_EXTRACT" -name node -type f -executable | head -n 1)
mv "$NODE_BIN" "$EMHTTP_DEST/bin/node"
chmod +x "$EMHTTP_DEST/bin/node"
rm -rf "$TMP_EXTRACT"

# 3. Download/Install Portable tmux (v3.6a)
TMUX_URL="https://github.com/mjakob-gh/build-static-tmux/releases/download/v3.6a/tmux.linux-amd64.gz"
echo "Downloading portable tmux (v3.6a)..."
rm -f "$CONFIG_DIR/tmux"
wget -q -O "$CONFIG_DIR/tmux.gz" "$TMUX_URL"
gunzip -f "$CONFIG_DIR/tmux.gz"
cp "$CONFIG_DIR/tmux" "$EMHTTP_DEST/bin/tmux"
chmod +x "$EMHTTP_DEST/bin/tmux"

# 4. Create wrappers in /usr/local/bin
cat &lt;&lt; 'EOF' &gt; /usr/local/bin/gemini
#!/bin/bash
"/usr/local/emhttp/plugins/unraid-geminicli/bin/node" "/usr/local/emhttp/plugins/unraid-geminicli/bin/gemini.mjs" "$@"
EOF
chmod +x /usr/local/bin/gemini

if [ ! -f /usr/local/bin/tmux ]; then
    ln -sf "$EMHTTP_DEST/bin/tmux" /usr/local/bin/tmux
fi

# 5. Download/Install Plugin Files
download_file() {
    local src=$1
    local dest=$2
    local dir=$(dirname "$EMHTTP_DEST/$dest")
    mkdir -p "$dir"
    echo "Downloading $dest..."
    # Bypass caching
    wget -q -O "$EMHTTP_DEST/$dest" "$GIT_URL/$src?v=$VERSION"
    if [[ "$dest" == *.sh || "$dest" == *.php || "$dest" == *.page ]]; then
        sed -i 's/\r$//' "$EMHTTP_DEST/$dest"
    fi
}

download_file "src/scripts/gemini-shell.sh" "scripts/gemini-shell.sh"
chmod +x "$EMHTTP_DEST/scripts/gemini-shell.sh"

download_file "src/GeminiCLI.page" "GeminiCLI.page"
download_file "src/GeminiSettings.page" "GeminiSettings.page"
download_file "src/GeminiAjax.php" "GeminiAjax.php"
download_file "src/includes/GeminiSettings.php" "includes/GeminiSettings.php"
download_file "src/assets/ui/index.js" "assets/ui/index.js"
download_file "src/assets/ui/index.css" "assets/ui/index.css"
download_file "src/unraid-geminicli.png" "unraid-geminicli.png"
download_file "src/README.md" "README.md"

# Sync menu visibility after install
php -r "require_once '/usr/local/emhttp/plugins/unraid-geminicli/includes/GeminiSettings.php'; \$config = getGeminiConfig(); updateGeminiMenuVisibility(\$config['enable_tab']); saveGeminiConfig(['version' => '2026.03.02.17']);"

echo "--- INSTALL COMPLETE ---"
</INLINE>
</FILE>

<!-- 2. REMOVE -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
#!/bin/bash
NAME="unraid-geminicli"
PLUGIN_DIR="/usr/local/emhttp/plugins/$NAME"
echo "Removing $NAME..."
rm -rf "$PLUGIN_DIR"
rm -f /usr/local/bin/gemini
removepkg "$NAME" &gt; /dev/null 2&gt;&amp;1
echo "Uninstall of $NAME complete."
exit 0
</INLINE>
</FILE>

</PLUGIN>
