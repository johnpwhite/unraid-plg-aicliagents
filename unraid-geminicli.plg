<!-- 1. INSTALLER SCRIPT -->
<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
set -e
NAME="unraid-geminicli"
VERSION="&version;"
GIT_URL="&gitURL;"
GEMINI_JS_URL="https://github.com/google-gemini/gemini-cli/releases/download/v0.30.0-preview.5/gemini.js"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"
CONFIG_DIR="/boot/config/plugins/$NAME"

echo "--- INSTALL START ---"
# Force cleanup of any old processes during install to ensure clean state
echo "Cleaning up existing processes..."
ps -ef | grep geminiterm.sock | grep -v grep | awk '{print $2}' | xargs kill -9 > /dev/null 2>&amp;1 || true
tmux kill-session -t gemini-cli > /dev/null 2>&amp;1 || true
rm -f /var/run/geminiterm.sock
rm -f /var/run/unraid-geminicli.pid

# Aggressive cleanup of ALL previous assets to ensure fresh load
rm -rf "$EMHTTP_DEST"
mkdir -p "$EMHTTP_DEST/bin"
mkdir -p "$EMHTTP_DEST/scripts"
mkdir -p "$CONFIG_DIR"

# 1. Download gemini.js to /boot (persistence)
echo "Downloading gemini.mjs..."
wget -q -O "$CONFIG_DIR/gemini.mjs" "$GEMINI_JS_URL?v=$VERSION"
# Copy to RAM for execution
cp "$CONFIG_DIR/gemini.mjs" "$EMHTTP_DEST/bin/gemini.mjs"

# 2. Download/Extract Portable Node.js (v20.11.0)
NODE_TAR="node-v20.11.0-linux-x64.tar.xz"
NODE_URL="https://nodejs.org/dist/v20.11.0/$NODE_TAR"

if [ ! -f "$CONFIG_DIR/$NODE_TAR" ]; then
    echo "Downloading portable Node.js (v20.11.0)..."
    wget -q -O "$CONFIG_DIR/$NODE_TAR" "$NODE_URL"
fi

echo "Extracting Node.js binary..."
TMP_EXTRACT="/tmp/node-extract-$$"
mkdir -p "$TMP_EXTRACT"
tar -xf "$CONFIG_DIR/$NODE_TAR" -C "$TMP_EXTRACT"

NODE_BIN=$(find "$TMP_EXTRACT" -name node -type f -executable | head -n 1)
mv "$NODE_BIN" "$EMHTTP_DEST/bin/node"
chmod +x "$EMHTTP_DEST/bin/node"
rm -rf "$TMP_EXTRACT"

# 3. Download/Install Portable tmux (v3.5a)
TMUX_URL="https://github.com/pythops/tmux-linux-binary/releases/download/v3.5a/tmux-linux-x86_64"
if [ ! -f "$CONFIG_DIR/tmux" ]; then
    echo "Downloading portable tmux (v3.5a)..."
    wget -q -O "$CONFIG_DIR/tmux" "$TMUX_URL"
fi
cp "$CONFIG_DIR/tmux" "$EMHTTP_DEST/bin/tmux"
chmod +x "$EMHTTP_DEST/bin/tmux"

# 4. Create wrappers in /usr/local/bin
cat &lt;&lt; 'EOF' &gt; /usr/local/bin/gemini
#!/bin/bash
"/usr/local/emhttp/plugins/unraid-geminicli/bin/node" "/usr/local/emhttp/plugins/unraid-geminicli/bin/gemini.mjs" "$@"
EOF
chmod +x /usr/local/bin/gemini

if [ ! -f /usr/local/bin/tmux ]; then
    ln -sf "$EMHTTP_DEST/bin/tmux" /usr/local/bin/tmux
fi

# 5. Download/Install Plugin Files
download_file() {
    local src=$1
    local dest=$2
    local dir=$(dirname "$EMHTTP_DEST/$dest")
    mkdir -p "$dir"
    echo "Downloading $dest..."
    # Bypass caching
    wget -q -O "$EMHTTP_DEST/$dest" "$GIT_URL/$src?v=$VERSION"
    if [[ "$dest" == *.sh || "$dest" == *.php || "$dest" == *.page ]]; then
        sed -i 's/\r$//' "$EMHTTP_DEST/$dest"
    fi
}

download_file "src/scripts/gemini-shell.sh" "scripts/gemini-shell.sh"
chmod +x "$EMHTTP_DEST/scripts/gemini-shell.sh"

download_file "src/GeminiCLI.page" "GeminiCLI.page"
download_file "src/GeminiSettings.page" "GeminiSettings.page"
download_file "src/includes/GeminiSettings.php" "includes/GeminiSettings.php"
download_file "src/assets/ui/index.js" "assets/ui/index.js"
download_file "src/assets/ui/index.css" "assets/ui/index.css"
download_file "src/gemini-cli.png" "gemini-cli.png"
download_file "src/README.md" "README.md"

# Sync menu visibility after install
php -r "require_once '/usr/local/emhttp/plugins/unraid-geminicli/includes/GeminiSettings.php'; \$config = getGeminiConfig(); updateGeminiMenuVisibility(\$config['enable_tab']);"

echo "--- INSTALL COMPLETE ---"
</INLINE>
</FILE>

<!-- 2. REMOVE -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
#!/bin/bash
NAME="unraid-geminicli"
PLUGIN_DIR="/usr/local/emhttp/plugins/$NAME"
echo "Removing $NAME..."
rm -rf "$PLUGIN_DIR"
rm -f /usr/local/bin/gemini
removepkg "$NAME" &gt; /dev/null 2&gt;&amp;1
echo "Uninstall of $NAME complete."
exit 0
</INLINE>
</FILE>

</PLUGIN>
